{
    "name": "litgroup/enumerable",
    "description": "Implementation of the enumerable type for PHP.",
    "keywords": [
        "enumerable",
        "enum"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Roman Shamritskiy",
            "email": "roman@litgroup.ru"
        }
    ],
    "autoload": {
        "psr-4": {
            "LitGroup\\Enumerable\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\LitGroup\\Enumerable\\": "test"
        }
    },
    "scripts": {
        "test": "XDEBUG_MODE=\"coverage\" vendor/bin/phpunit",
        "test-coverage": "@test --coverage-html=build/reports/coverage"
    },
    "archive": {
        "exclude": [
            "/tests",
            "/phpunit.xml.dist",
            ".gitignore"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    }
}
